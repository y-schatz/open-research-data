###  http://www.hesge.ch/open-research-data/ontologies/attributes#Discipline
:Discipline rdf:type owl:NamedIndividual ,
                     core:Attribute ;
            rdfs:label "Discipline"@en ,
                       "Discipline"@fr ,
                       "Fachbereich"@de .


###  http://www.hesge.ch/open-research-data/ontologies/attributes#ModelViewDefinition
:ModelViewDefinition rdf:type owl:NamedIndividual ,
                              core:Attribute ;
                     rdfs:label "Définition de vue du modèle"@fr ,
                                "Model View Definition"@en ,
                                "Modellansichtsdefinition"@de .


