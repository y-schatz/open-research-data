@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix core: <http://www.hesge.ch/open-research-data/ontologies/core#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.hesge.ch/open-research-data/ontologies/formats#> .

<http://www.hesge.ch/open-research-data/ontologies/formats> rdf:type owl:Ontology ;
                                                             owl:imports <https://raw.githubusercontent.com/y-schatz/open-research-data/refs/heads/main/ontologies/core.owl> .

#################################################################
#    Individuals
#################################################################

###  http://www.hesge.ch/open-research-data/ontologies/formats#AutoCADDrawing
:AutoCADDrawing rdf:type owl:NamedIndividual ,
                         core:DataFormat ;
                core:fileExtension ".dwg" ;
                core:mimeType "image/vnd.dwg" .


###  http://www.hesge.ch/open-research-data/ontologies/formats#BuildingCollaborationFormat
:BuildingCollaborationFormat rdf:type owl:NamedIndividual ;
                             core:fileExtension ".bcf" ;
                             core:mimeType "application/octet-stream" .


###  http://www.hesge.ch/open-research-data/ontologies/formats#CommaSeparatedValues
:CommaSeparatedValues rdf:type owl:NamedIndividual ;
                      core:fileExtension ".csv" ;
                      core:mimeType "text/csv" .


###  http://www.hesge.ch/open-research-data/ontologies/formats#DrawingExchangeFormat
:DrawingExchangeFormat rdf:type owl:NamedIndividual ;
                       core:fileExtension ".dxf" ;
                       core:mimeType "image/vnd.dxf" .


###  http://www.hesge.ch/open-research-data/ontologies/formats#IndustryFoundationClasses
:IndustryFoundationClasses rdf:type owl:NamedIndividual ;
                           core:field "MVD" ;
                           core:fileExtension ".ifc" ;
                           core:mimeType "application/x-step" .


###  http://www.hesge.ch/open-research-data/ontologies/formats#JavaScriptObjectNotation
:JavaScriptObjectNotation rdf:type owl:NamedIndividual ;
                          core:fileExtension ".json" ;
                          core:mimeType "application/json" .


###  http://www.hesge.ch/open-research-data/ontologies/formats#PortableDocumentFormat
:PortableDocumentFormat rdf:type owl:NamedIndividual ;
                        core:fileExtension ".pdf" ;
                        core:mimeType "application/pdf" .


